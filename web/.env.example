# LLM generation (server-side only)
# Use gemini in Vercel, or ollama for a local-only web app.
GENERATION_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
OLLAMA_BASE_URL=http://shalini.local:11434
OLLAMA_MODEL=qwen3.6:35b-a3b

# Local-only fable library; this folder sits outside the Git repository.
LOCAL_LIBRARY_ENABLED=true
LOCAL_LIBRARY_DIR=/absolute/path/to/LyricalFableLibrary

# Supabase persistence (server-side service role only)
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=story-audio

# Local-only narration. Do not set these in Vercel: hosted narration is disabled.
NARRATION_PROVIDER=kokoro
KOKORO_PYTHON=/absolute/path/to/python-with-kokoro

# Optional public origin
NEXT_PUBLIC_SITE_URL=http://localhost:3000
