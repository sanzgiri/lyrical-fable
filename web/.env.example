# LLM generation (server-side only)
# Use gemini in Vercel, or ollama for a local-only web app.
GENERATION_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
OLLAMA_BASE_URL=http://shalini.local:11434
OLLAMA_MODEL=qwen3.6:35b-a3b

# Supabase persistence (server-side service role only)
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=story-audio

# Hosted narration (server-side only; local Kokoro remains available via scripts/)
OPENAI_API_KEY=
OPENAI_TTS_MODEL=tts-1
OPENAI_TTS_VOICE=alloy

# Optional public origin
NEXT_PUBLIC_SITE_URL=http://localhost:3000
